#!/usr/bin/env bash
set -euo pipefail

if [[ ! -d "/data/data/com.termux" ]]; then
  echo "Error: termux-client/np is supported only inside Termux on Android." >&2
  echo "Use newproj and devenv directly on the host, or use the desktop client." >&2
  exit 2
fi

read -r -p "Repo name: " NAME
NAME="$(echo "$NAME" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9 -]//g; s/[ ]+/-/g; s/^-+|-+$//g')"
[[ -n "$NAME" ]] || { echo "Empty name"; exit 2; }
CFG_FILE="$HOME/.config/termux-client/config"
# shellcheck disable=SC1090
source "$CFG_FILE"

run_newproj_then_open() {
  local repo="$1"
  local cmd="command -v newproj >/dev/null || { echo 'Error: newproj is not installed on the host'; exit 127; }; command -v devenv >/dev/null || { echo 'Error: devenv is not installed on the host'; exit 127; }; newproj $(printf '%q' "$repo") private && devenv open $(printf '%q' "$repo")"
  exec ssh -t "$HOST" "bash -lc $(printf '%q' "$cmd")"
}

# Termux: create/clone the repo remotely, then enter the canonical devenv workspace
run_newproj_then_open "$NAME"
