#!/usr/bin/env bash
set -euo pipefail

if [[ ! -d "/data/data/com.termux" ]]; then
  echo "Error: termux-client/op is supported only inside Termux on Android." >&2
  echo "Use plain SSH or the tmux-workspace desktop client on non-Termux machines." >&2
  exit 2
fi

WORKSPACE="${WORKSPACE_ROOT_REMOTE:-$HOME/src}"
CFG_FILE="$HOME/.config/termux-client/config"
# shellcheck disable=SC1090
source "$CFG_FILE"

run_workspace_open() {
  local repo="$1"
  local cmd="command -v devenv >/dev/null || { echo 'Error: devenv is not installed on the host'; exit 127; }; devenv open $(printf '%q' "$repo")"
  exec ssh -t "$HOST" "bash -lc $(printf '%q' "$cmd")"
}

REPOS="$(
  ssh "$HOST" "bash -lc 'cd \"${WORKSPACE}\" && for d in */.git; do echo \${d%/.git}; done 2>/dev/null | sort'" \
  || true
)"

if [[ -z "$REPOS" ]]; then
  echo "No repos found in ${WORKSPACE}."
  echo "Tip: run np to create a new project."
  exit 2
fi

CHOICE="$(printf '%s\n' "$REPOS" | fzf --prompt='Open repo> ' --height=40% --reverse)"
[[ -n "${CHOICE:-}" ]] || exit 0

vscode-web "${WORKSPACE}/${CHOICE}" >/dev/null 2>&1 || true
run_workspace_open "$CHOICE"
